# ── LINE Messaging API ────────────────────────────────────────
# LINE Developers → チャネル → Messaging API タブ で取得
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ── Google Gemini API ─────────────────────────────────────────
# https://aistudio.google.com/app/apikey で無料取得
GEMINI_API_KEY=your_gemini_api_key_here

# ── メルカリ クッキー ─────────────────────────────────────────
# export_cookies.js をブラウザのコンソールで実行してコピー
# 例: [{"name":"_token","value":"xxx","domain":"jp.mercari.com","path":"/"},...]
MERCARI_COOKIES=[{"name":"example","value":"example","domain":"jp.mercari.com","path":"/"}]
